---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const featuredProjects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="首頁">
  <!-- Hero -->
  <section class="py-12 sm:py-16">
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      Hi, I'm <span class="text-primary-600 dark:text-primary-400">CCY</span>
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
      歡迎來到我的部落格。這裡記錄了我在軟體開發路上的學習筆記、技術探索與個人隨筆。
    </p>
  </section>

  <!-- Latest Posts -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">最新文章</h2>
      <a href="/blog" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">
        查看全部 &rarr;
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {allPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          tags={post.data.tags}
          slug={post.id}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">精選作品</h2>
        <a href="/projects" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">
          查看全部 &rarr;
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            url={project.data.url}
            github={project.data.github}
            image={project.data.image}
            tech={project.data.tech}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
