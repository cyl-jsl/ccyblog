---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogListPage from '../../components/BlogListPage.astro';
import { getCollection } from 'astro:content';

const postsPerPage = 10;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
const allCategories = [...new Set(allPosts.map((post) => post.data.category))].sort();

const totalPages = Math.ceil(allPosts.length / postsPerPage);
const paginatedPosts = allPosts.slice(0, postsPerPage);
---

<BaseLayout title="Blog" description="所有文章列表">
  <BlogListPage
    posts={paginatedPosts}
    currentPage={1}
    totalPages={totalPages}
    allCategories={allCategories}
    allTags={allTags}
  />
</BaseLayout>
