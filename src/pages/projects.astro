---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const featuredProjects = projects
  .filter((project) => project.data.featured)
  .slice(0, 3);

const featuredIds = new Set(featuredProjects.map((project) => project.id));
const otherProjects = projects.filter((project) => !featuredIds.has(project.id));
---

<BaseLayout title="Projects" description="我的作品集">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <section class="max-w-[720px] mb-10">
      <p class="text-[10px] uppercase tracking-[4px] text-muted mb-3">Projects</p>
      <h1 class="font-serif text-[28px] font-normal text-heading mb-4">作品</h1>
      <p class="text-[14px] text-secondary leading-relaxed mb-4">
        這裡收的不是練習題，而是從真實摩擦長出來的 side projects。有些來自工作流程裡反覆出現的麻煩，有些來自生活或遊戲裡那種「這件事不該這麼麻煩」的瞬間。
      </p>
      <p class="text-[14px] text-secondary leading-relaxed">
        如果文章比較像我怎麼想，這一頁比較像我怎麼把那些想法落成工具。每個作品都可以點進去看更完整的問題、方案與成果。
      </p>
    </section>

    {featuredProjects.length > 0 && (
      <section class="mb-12">
        <div class="flex items-center justify-between gap-4 mb-6">
          <div>
            <p class="text-[10px] uppercase tracking-[4px] text-muted mb-2">Selected</p>
            <h2 class="font-serif text-[20px] font-normal text-heading">先看這三個</h2>
          </div>
          <p class="hidden md:block text-[12px] text-muted max-w-[24rem] text-right leading-relaxed">
            這幾個最能代表我把 AI workflow、automation 和個人產品思路接在一起的方式。
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              url={project.data.url}
              github={project.data.github}
              image={project.data.image}
              slug={project.id}
              tech={project.data.tech}
            />
          ))}
        </div>
      </section>
    )}

    {otherProjects.length > 0 && (
      <section class="border-t border-divider pt-10">
        <div class="flex items-center justify-between gap-4 mb-6">
          <h2 class="font-serif text-[20px] font-normal text-heading">全部作品</h2>
          <p class="text-[12px] text-muted">共 {projects.length} 個專案</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {otherProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              url={project.data.url}
              github={project.data.github}
              image={project.data.image}
              slug={project.id}
              tech={project.data.tech}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
