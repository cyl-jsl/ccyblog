---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="text-sm">
    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-3">目錄</h4>
    <ul class="space-y-1.5">
      {filteredHeadings.map((heading) => (
        <li style={heading.depth === 3 ? 'padding-left: 1rem;' : ''}>
          <a
            href={`#${heading.slug}`}
            class="text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors leading-snug block"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
