---
import PostCard from './PostCard.astro';
import { categoryToSlug } from '../utils/category';

interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      category: string;
      tags: string[];
      heroImage?: string;
    };
  }>;
  currentPage: number;
  totalPages: number;
  allCategories: string[];
  allTags: string[];
}

const { posts, currentPage, totalPages, allCategories, allTags } = Astro.props;

function pageUrl(page: number) {
  return page === 1 ? '/blog' : `/blog/page/${page}`;
}
---

<div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-8">
  <!-- Posts -->
  <div>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">Blog</h1>
    <div class="grid gap-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          tags={post.data.tags}
          slug={post.id}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>

    {/* Pagination */}
    {totalPages > 1 && (
      <nav class="flex justify-center gap-2 mt-10">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
          <a
            href={pageUrl(page)}
            class:list={[
              'px-3 py-1.5 rounded text-sm font-medium transition-colors',
              page === currentPage
                ? 'bg-primary-600 text-white'
                : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800',
            ]}
          >
            {page}
          </a>
        ))}
      </nav>
    )}
  </div>

  <!-- Sidebar -->
  <aside class="hidden lg:block">
    <div class="sticky top-20 space-y-8">
      {/* Categories */}
      <div>
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-3 text-sm">分類</h3>
        <ul class="space-y-1.5">
          {allCategories.map((cat) => (
            <li>
              <a
                href={`/blog/categories/${categoryToSlug(cat)}`}
                class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              >
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Tags */}
      <div>
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-3 text-sm">標籤</h3>
        <div class="flex flex-wrap gap-1.5">
          {allTags.map((tag) => (
            <a
              href={`/blog/tags/${tag}`}
              class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 px-2 py-0.5 rounded transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </div>
  </aside>
</div>
